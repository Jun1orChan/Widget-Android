<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <org.jun1or.widget.pulltorefresh.PullToRefreshLayout
        android:id="@+id/crl"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:widget_complete_delay="2000">

        <org.jun1or.widget.pulltorefresh.header.ClassicHeaderView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"></org.jun1or.widget.pulltorefresh.header.ClassicHeaderView>

        <android.support.v7.widget.RecyclerView
            android:id="@+id/rv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </org.jun1or.widget.pulltorefresh.PullToRefreshLayout>

</LinearLayout>